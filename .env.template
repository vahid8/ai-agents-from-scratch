# Copy this file to .env and fill in your key:   cp .env.template .env
#
# Each key has two options — pick ONE per provider:
#   Option A (simplest): paste the key directly.
#   Option B (safer): keep the key in a file OUTSIDE the project and point to it,
#   so your .env only holds a path and is safe to show on screen.

# --- Gemini (Episode 1+) — free key: https://aistudio.google.com/apikey ---
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_API_KEY_FILE=~/.secrets/gemini.key

# --- Tavily (Episode 4+) — agent-tuned web search, free tier: https://tavily.com ---
# web_search prefers Tavily for quality; with NO key it falls back to keyless
# DuckDuckGo, so this is optional — add it for better search results.
# TAVILY_API_KEY=your_tavily_api_key_here
# TAVILY_API_KEY_FILE=~/.secrets/tavily.key
